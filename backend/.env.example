# Copy to ../.env (project root) and fill in real values.
# The API container reads this file via docker-compose `env_file: .env`.

# --- Postgres (used by docker-compose to initialize the db service) ---
POSTGRES_USER=upsc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=upsc_db

# --- Backend connection strings ---
DATABASE_URL=postgresql+asyncpg://upsc:change-me-strong-password@postgres:5432/upsc_db
REDIS_URL=redis://redis:6379

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET=replace-with-64-char-hex-secret
JWT_REFRESH_SECRET=replace-with-different-64-char-hex-secret

# --- Razorpay (leave blank if payments are disabled) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_MONTHLY=
RAZORPAY_PLAN_ID_ANNUAL=

# --- Firebase Admin SDK (from service-account JSON) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key field from the service-account JSON verbatim, including
# the literal \n escapes. Keep the surrounding double quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY_CONTENTS\n-----END PRIVATE KEY-----\n"

# --- Admin bootstrap (used once to create the first superadmin) ---
ADMIN_SECRET_KEY=change-me-long-random-string
